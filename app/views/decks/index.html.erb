<%# T027 — Decks index: list with card count, due count placeholder, action buttons %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h2">My Decks</h1>
  <%= link_to "＋ New Deck", new_deck_path, class: "btn btn-primary" %>
</div>

<% if @decks.empty? %>
  <div class="text-center py-5 text-muted">
    <p class="fs-5">No decks yet. Create your first deck to get started!</p>
    <%= link_to "Create a Deck", new_deck_path, class: "btn btn-outline-primary mt-2" %>
  </div>
<% else %>
  <ul class="list-group list-group-flush" id="decks-list">
    <% @decks.each do |deck| %>
      <li class="list-group-item d-flex justify-content-between align-items-center py-3">
        <div>
          <%= link_to deck.name, deck_path(deck), class: "fw-semibold text-decoration-none fs-5" %>
          <% if deck.description.present? %>
            <p class="text-muted small mb-0"><%= deck.description %></p>
          <% end %>
          <div class="mt-1">
            <span class="badge bg-secondary me-1">
              <%= pluralize(deck.cards.size, "card") %>
            </span>
          </div>
        </div>
        <div class="btn-group" role="group">
          <%= link_to "Study", new_deck_study_session_path(deck),
                      class: "btn btn-sm btn-success" %>
          <%= link_to "Edit", edit_deck_path(deck),
                      class: "btn btn-sm btn-outline-secondary" %>
          <%= button_to "Delete", deck_path(deck),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        aria: { label: "Delete deck #{deck.name}" },
                        data: { turbo_confirm: "Delete deck and all its cards?" } %>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>
