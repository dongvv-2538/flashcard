<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Flashcard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Bootstrap 5 CSS — Constitution Principle III: UX Consistency %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <%# Bootstrap fixed-top navbar %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
      <div class="container">
        <%= link_to "🃏 Flashcard", "/", class: "navbar-brand fw-bold" %>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false"
                aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <% if logged_in? %>
              <li class="nav-item">
                <%= link_to "My Decks", decks_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Review Queue", reviews_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>

          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <% if logged_in? %>
              <li class="nav-item">
                <span class="nav-link text-light">
                  <i class="bi bi-person-circle"></i>
                  <%= current_user.username %>
                </span>
              </li>
              <li class="nav-item">
                <%= link_to "Log out", session_path,
                            data: { turbo_method: :delete },
                            class: "nav-link" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Log in", new_session_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Register", new_user_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# Flash messages — auto-dismiss after 4 s via application.js %>
    <div class="flash-messages" aria-live="polite">
      <% flash.each do |type, message| %>
        <%
          bs_class = case type.to_s
                     when "notice"  then "alert-success"
                     when "alert"   then "alert-danger"
                     when "info"    then "alert-info"
                     when "warning" then "alert-warning"
                     else "alert-secondary"
                     end
        %>
        <div class="alert <%= bs_class %> alert-dismissible fade show flash-auto-dismiss" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <%# Main content %>
    <main class="container mt-4">
      <%= yield %>
    </main>

    <%# Bootstrap 5 JS bundle (includes Popper) %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmTIb/5I+zIpzeIzfQ2I5JqCf8/w"
            crossorigin="anonymous"></script>
    <%# Application JS (auto-dismiss flash, jQuery helpers) %>
    <%= javascript_include_tag "application", defer: true %>
  </body>
</html>
