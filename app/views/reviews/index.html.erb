<%# T056 — Review Queue index view %>
<% content_for :title, "Review Queue" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">📋 Review Queue</h1>
  <span class="text-muted small">Today: <%= Date.today.strftime("%B %-d, %Y") %></span>
</div>

<% if @grouped_by_deck.any? %>

  <% @grouped_by_deck.each do |deck, cards| %>
    <div class="card mb-3 shadow-sm">
      <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
          <h2 class="h5 mb-1">
            <%= link_to deck.name, deck_path(deck), class: "text-decoration-none" %>
          </h2>
          <span class="badge bg-warning text-dark fs-6">
            <%= cards.size %> card<%= cards.size == 1 ? "" : "s" %> due
          </span>
        </div>

        <%= button_to "Start Review",
                      reviews_path,
                      method: :post,
                      params: { deck_id: deck.id },
                      class: "btn btn-primary",
                      aria: { label: "Start review for #{deck.name}" } %>
      </div>
    </div>
  <% end %>

<% else %>
  <%# No-due-cards state %>
  <div class="text-center py-5">
    <p class="fs-1 mb-2">🎉</p>
    <h2 class="h4 mb-2">No cards due</h2>

    <% if @next_review_date %>
      <p class="text-muted">
        Your next review is scheduled for
        <strong><%= @next_review_date.strftime("%B %-d, %Y") %></strong>.
      </p>
    <% else %>
      <p class="text-muted">
        You haven't studied any cards yet, or all cards are brand new.
        <%= link_to "Browse your decks", decks_path %> to start a session.
      </p>
    <% end %>
  </div>
<% end %>
